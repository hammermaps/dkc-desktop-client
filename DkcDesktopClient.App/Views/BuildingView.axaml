<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DkcDesktopClient.App.ViewModels"
             x:Class="DkcDesktopClient.App.Views.BuildingView"
             x:DataType="vm:BuildingViewModel">
  <Grid RowDefinitions="Auto, Auto, Auto, Auto, *" Margin="16" RowSpacing="8">

    <!-- Toolbar -->
    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8">
      <TextBlock Text="Buildings" FontSize="24" FontWeight="Bold" VerticalAlignment="Center"/>
      <Button Content="Load" Command="{Binding LoadBuildingsCommand}"/>
      <Separator Width="1" Background="#CCCCCC" Margin="4,0"/>
      <Button Content="New Building" Command="{Binding ShowCreateBuildingFormCommand}"/>
      <Button Content="Edit Building" Command="{Binding ShowEditBuildingFormCommand}"/>
      <Separator Width="1" Background="#CCCCCC" Margin="4,0"/>
      <Button Content="New Inspection" Command="{Binding ShowCreateInspectionFormCommand}"/>
      <Button Content="Edit Inspection" Command="{Binding ShowEditInspectionFormCommand}"/>
      <Button Content="Complete" Command="{Binding CompleteInspectionCommand}"/>
    </StackPanel>

    <!-- Error / Progress -->
    <TextBlock Grid.Row="1" Text="{Binding ErrorMessage}" Foreground="Red"
               IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
    <ProgressBar Grid.Row="1" IsIndeterminate="True" IsVisible="{Binding IsLoading}" Height="4" VerticalAlignment="Bottom"/>

    <!-- Building form -->
    <Border Grid.Row="2" IsVisible="{Binding IsBuildingFormVisible}"
            Background="#F0F4F8" BorderThickness="1" BorderBrush="#CBD5E0" CornerRadius="4" Padding="12">
      <StackPanel Spacing="8">
        <TextBlock Text="Building" FontSize="15" FontWeight="SemiBold"/>
        <TextBlock Text="{Binding BuildingFormError}" Foreground="Red"
                   IsVisible="{Binding BuildingFormError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
        <Grid ColumnDefinitions="100,8,*,16,100,8,*" RowDefinitions="Auto,8,Auto,8,Auto" RowSpacing="0">
          <TextBlock Grid.Row="0" Grid.Column="0" Text="Name *" VerticalAlignment="Center"/>
          <TextBox Grid.Row="0" Grid.Column="2" Text="{Binding FormBuildingName}" PlaceholderText="Building name (required)"/>
          <TextBlock Grid.Row="0" Grid.Column="4" Text="Enabled" VerticalAlignment="Center"/>
          <CheckBox Grid.Row="0" Grid.Column="6" IsChecked="{Binding FormBuildingEnabled}"/>

          <TextBlock Grid.Row="2" Grid.Column="0" Text="Address" VerticalAlignment="Center"/>
          <TextBox Grid.Row="2" Grid.Column="2" Text="{Binding FormBuildingAddress}" PlaceholderText="Address"/>
          <TextBlock Grid.Row="2" Grid.Column="4" Text="Description" VerticalAlignment="Center"/>
          <TextBox Grid.Row="2" Grid.Column="6" Text="{Binding FormBuildingDescription}" PlaceholderText="Description"/>

          <TextBlock Grid.Row="4" Grid.Column="0" Text="Complete Result" VerticalAlignment="Center"/>
          <ComboBox Grid.Row="4" Grid.Column="2" ItemsSource="{x:Static vm:BuildingViewModel.ResultOptions}"
                    SelectedItem="{Binding FormCompleteResult}" MinWidth="120"/>
          <TextBlock Grid.Row="4" Grid.Column="4" Text="Complete Notes" VerticalAlignment="Center"/>
          <TextBox Grid.Row="4" Grid.Column="6" Text="{Binding FormCompleteNotes}" PlaceholderText="Notes for completion"/>
        </Grid>
        <StackPanel Orientation="Horizontal" Spacing="8">
          <Button Content="Save" Command="{Binding SaveBuildingCommand}"/>
          <Button Content="Cancel" Command="{Binding CancelBuildingFormCommand}"/>
          <ProgressBar IsIndeterminate="True" IsVisible="{Binding IsSavingBuilding}" Width="80" Height="16" VerticalAlignment="Center"/>
        </StackPanel>
      </StackPanel>
    </Border>

    <!-- Inspection form -->
    <Border Grid.Row="3" IsVisible="{Binding IsInspectionFormVisible}"
            Background="#FFF9E6" BorderThickness="1" BorderBrush="#F6C90E" CornerRadius="4" Padding="12">
      <StackPanel Spacing="8">
        <TextBlock Text="Inspection" FontSize="15" FontWeight="SemiBold"/>
        <TextBlock Text="{Binding InspectionFormError}" Foreground="Red"
                   IsVisible="{Binding InspectionFormError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
        <Grid ColumnDefinitions="100,8,*,16,100,8,*" RowDefinitions="Auto,8,Auto,8,Auto" RowSpacing="0">
          <TextBlock Grid.Row="0" Grid.Column="0" Text="Title" VerticalAlignment="Center"/>
          <TextBox Grid.Row="0" Grid.Column="2" Text="{Binding FormInspectionTitle}" PlaceholderText="Inspection title"/>
          <TextBlock Grid.Row="0" Grid.Column="4" Text="Date" VerticalAlignment="Center"/>
          <TextBox Grid.Row="0" Grid.Column="6" Text="{Binding FormInspectionDate}" PlaceholderText="YYYY-MM-DD"/>

          <TextBlock Grid.Row="2" Grid.Column="0" Text="Status" VerticalAlignment="Center"/>
          <ComboBox Grid.Row="2" Grid.Column="2" ItemsSource="{x:Static vm:BuildingViewModel.InspectionStatusOptions}"
                    SelectedItem="{Binding FormInspectionStatus}" MinWidth="120"/>
          <TextBlock Grid.Row="2" Grid.Column="4" Text="Weather" VerticalAlignment="Center"/>
          <TextBox Grid.Row="2" Grid.Column="6" Text="{Binding FormInspectionWeather}" PlaceholderText="Weather"/>

          <TextBlock Grid.Row="4" Grid.Column="0" Text="Attendees" VerticalAlignment="Center"/>
          <TextBox Grid.Row="4" Grid.Column="2" Text="{Binding FormInspectionAttendees}" PlaceholderText="Attendees"/>
          <TextBlock Grid.Row="4" Grid.Column="4" Text="Notes" VerticalAlignment="Center"/>
          <TextBox Grid.Row="4" Grid.Column="6" Text="{Binding FormInspectionNotes}" PlaceholderText="General notes"/>
        </Grid>
        <StackPanel Orientation="Horizontal" Spacing="8">
          <Button Content="Save" Command="{Binding SaveInspectionCommand}"/>
          <Button Content="Cancel" Command="{Binding CancelInspectionFormCommand}"/>
          <ProgressBar IsIndeterminate="True" IsVisible="{Binding IsSavingInspection}" Width="80" Height="16" VerticalAlignment="Center"/>
        </StackPanel>
      </StackPanel>
    </Border>

    <!-- Main content: buildings + inspections + checkpoints -->
    <Grid Grid.Row="4" ColumnDefinitions="280, 8, *">
      <StackPanel Grid.Column="0" Spacing="4">
        <TextBlock Text="Buildings" FontWeight="SemiBold"/>
        <DataGrid ItemsSource="{Binding Buildings}" SelectedItem="{Binding SelectedBuilding}"
                  IsReadOnly="True" AutoGenerateColumns="False">
          <DataGrid.Columns>
            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
            <DataGridTextColumn Header="Address" Binding="{Binding Address}" Width="140"/>
          </DataGrid.Columns>
        </DataGrid>
      </StackPanel>
      <GridSplitter Grid.Column="1" Width="4"/>
      <Grid Grid.Column="2" RowDefinitions="*, 8, *">
        <StackPanel Grid.Row="0" Spacing="4">
          <TextBlock Text="Inspections" FontWeight="SemiBold"/>
          <DataGrid ItemsSource="{Binding Inspections}" SelectedItem="{Binding SelectedInspection}"
                    IsReadOnly="True" AutoGenerateColumns="False">
            <DataGrid.Columns>
              <DataGridTextColumn Header="Title" Binding="{Binding Title}" Width="*"/>
              <DataGridTextColumn Header="Date" Binding="{Binding InspectionDate}" Width="110"/>
              <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="90"/>
              <DataGridTextColumn Header="Result" Binding="{Binding OverallResult}" Width="90"/>
            </DataGrid.Columns>
          </DataGrid>
        </StackPanel>
        <GridSplitter Grid.Row="1" Height="4"/>
        <ScrollViewer Grid.Row="2">
          <StackPanel Margin="4" Spacing="8" IsVisible="{Binding InspectionDetail, Converter={x:Static ObjectConverters.IsNotNull}}">
            <TextBlock Text="Checkpoint Results" FontSize="16" FontWeight="SemiBold"/>
            <DataGrid ItemsSource="{Binding InspectionDetail.Results}" IsReadOnly="True" AutoGenerateColumns="False">
              <DataGrid.Columns>
                <DataGridTextColumn Header="Checkpoint" Binding="{Binding CheckpointName}" Width="*"/>
                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="90"/>
                <DataGridTextColumn Header="Note" Binding="{Binding Note}" Width="150"/>
                <DataGridTextColumn Header="Comment" Binding="{Binding Comment}" Width="150"/>
                <DataGridTextColumn Header="Editor" Binding="{Binding EditedByName}" Width="120"/>
              </DataGrid.Columns>
            </DataGrid>
          </StackPanel>
        </ScrollViewer>
      </Grid>
    </Grid>

  </Grid>
</UserControl>
